# App
APP_URL=http://localhost:3000

# SQLite (local-first, single Node process)
# DATA_DIR=./data
# DATABASE_PATH=./data/planner.db

# Encrypt X OAuth tokens at rest — required when ENABLE_X_SYNC=true
# Generate: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=

# xAI / Grok (server-only — never NEXT_PUBLIC_)
# Requires credits on your xAI team: https://console.x.ai
XAI_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1
XAI_MODEL=grok-4.5
XAI_TIMEOUT_MS=20000
# Web-backed research (Topics → Research latest) uses Responses + web_search.
# Longer timeout; not retried automatically (avoids duplicate paid searches).
XAI_RESEARCH_TIMEOUT_MS=90000

# X (Twitter) API — OAuth 2.0 confidential web app
# Portal: https://developer.x.com
# Callback: http://localhost:3000/api/auth/x/callback
X_CLIENT_ID=
X_CLIENT_SECRET=
X_SCOPES_READ=tweet.read users.read offline.access
X_SCOPES_POSTING=tweet.read users.read offline.access tweet.write

# Feature flags
ENABLE_X_SYNC=false
ENABLE_X_POSTING=false

DEFAULT_CHAR_LIMIT=280
